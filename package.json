{
  "name": "@thewitchcat/cli",
  "version": "1.0.1",
  "private": false,
  "description": "WitchcatCode - Multi-provider native CLI for AI code assistants",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/witchscottishfoldcat/WitchCatCode.git"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=24.0.0"
