    "start": "bun run ./src/bootstrap-entry.ts",
    "version": "bun run ./src/bootstrap-entry.ts --version",
    "dev:restore-check": "npx bun run ./src/dev-entry.ts",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "bin": {
