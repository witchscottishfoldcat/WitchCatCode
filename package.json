{
  "name": "@witchcat-code/cli",
  "version": "1.0.0",
  "private": false,
  "description": "WitchcatCode - Multi-provider native CLI for AI code assistants",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/witchscottishfoldcat/WitchCatCode.git"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "bun run ./src/bootstrap-entry.ts",
    "start": "bun run ./src/bootstrap-entry.ts",
    "version": "bun run ./src/bootstrap-entry.ts --version",
    "dev:restore-check": "bun run ./src/dev-entry.ts",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "bin": {
    "witchcat": "./src/bootstrap-entry.ts"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "*",
